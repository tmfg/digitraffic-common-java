<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- Temporary suppressions, check and update these periodically -->

    <!-- We are not using jakarta mail:
         In Jakarta Mail 2.0.2 it is possible to preform a SMTP Injection
         by utilizing the \r and \n UTF-8 characters to separate different messages.-->
    <suppress until="2027-01-01">
        <notes><![CDATA[file name: angus-activation-2.0.0.jar]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.eclipse\.angus/angus-activation@.*$</packageUrl>
        <cve>CVE-2025-7962</cve>
    </suppress>
    <!-- We dont use logger to send logs to remote servers -->
    <suppress until="2026-06-01">
        <notes><![CDATA[file name: log4j-api-2.24.3.jar]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j-api@.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>
    <!--
        Permanent suppressions
    -->

</suppressions>